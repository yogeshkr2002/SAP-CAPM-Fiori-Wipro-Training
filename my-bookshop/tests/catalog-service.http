### Variables
@baseUrl = http://localhost:4004/odata/v4/catalog

### Get service document (lists all entities in CatalogService)
GET {{baseUrl}}/

### Get all Books
GET {{baseUrl}}/Books

### Get all Books with author expanded
GET {{baseUrl}}/Books?$expand=author

### Get a single Book by ID (replace with a real ID from your CSV)
GET {{baseUrl}}/Books(17154825-a41f-4962-84aa-2e9f7598ca23)

### Filter Books by price greater than 50
GET {{baseUrl}}/Books?$filter=price gt 50

### Select only title and price fields
GET {{baseUrl}}/Books?$select=title,price

### Get all Authors with their books expanded
GET {{baseUrl}}/Authors?$expand=books

### Create a new Book (POST)
POST {{baseUrl}}/Books
Content-Type: application/json

{
  "title": "Wuthering Heights",
  "descr": "A classic gothic novel",
  "stock": 12,
  "price": 15.50,
  "currency": "USD"
}

### Update a Book (PATCH) - replace with real ID
PATCH {{baseUrl}}/Books(17154825-a41f-4962-84aa-2e9f7598ca23)
Content-Type: application/json

{
  "stock": 99
}

### Delete a Book - replace with real ID
DELETE {{baseUrl}}/Books(17154825-a41f-4962-84aa-2e9f7598ca23)

### Test stock validation - should fail with 400
POST {{baseUrl}}/Books
Content-Type: application/json

{
  "title": "Invalid Book",
  "stock": -5,
  "price": 10.00,
  "currency": "USD"
}
###======================================================
### Test not-null validation - missing title should fail
POST {{baseUrl}}/Books
Content-Type: application/json

{
  "stock": 5,
  "price": 20.00
}

### Test @assert.range - price too high should fail
POST {{baseUrl}}/Books
Content-Type: application/json

{
  "title": "Overpriced Book",
  "stock": 1,
  "price": 999999
}

### Test default values - omit stock and currency
POST {{baseUrl}}/Books
Content-Type: application/json

{
  "title": "Defaults Test Book",
  "price": 25.00
}

### Confirm stockValue is calculated correctly
GET {{baseUrl}}/Books?$select=title,stock,price,stockValue

###======================================================
### Bob (reader) tries to READ - should succeed
GET {{baseUrl}}/Books
Authorization: Basic bob:bob

### Bob (reader) tries to CREATE - should fail with 403
POST {{baseUrl}}/Books
Authorization: Basic bob:bob
Content-Type: application/json

{
  "title": "Unauthorized Book",
  "price": 10.00
}

### Alice (admin) tries to CREATE - should succeed
POST {{baseUrl}}/Books
Authorization: Basic alice:alice
Content-Type: application/json

{
  "title": "Admin Created Book",
  "price": 10.00
}

### No credentials at all - should fail with 401
GET {{baseUrl}}/Books
